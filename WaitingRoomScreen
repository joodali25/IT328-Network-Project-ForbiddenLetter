import javax.swing.*;
import java.awt.*;
import java.awt.geom.Ellipse2D;
import java.awt.geom.RoundRectangle2D;
import java.util.ArrayList;
import java.util.List;

public class WaitingRoomScreen extends JPanel {
    private List<String> currentPlayers = new ArrayList<>();
    
    // الألوان الجديدة المطلوبة
    private final Color offWhite = new Color(245, 241, 222); // سكري فاتح للعنوان والأسماء
    private final Color darkOffWhite = new Color(200, 195, 180); // سكري غامق للرسالة السفلية
    private final Color playerFillColor = new Color(112, 128, 144); // لون Slate Blue (أفضل من الأخضر)
    private final Color strokeColor = new Color(45, 45, 48); // لون الحدود
    
    private Image backgroundImage;

    public WaitingRoomScreen() {
        setLayout(new BorderLayout());
        setOpaque(false);

        try {
            backgroundImage = new ImageIcon("src/backgroundWaittingRoom.png").getImage();
            if (backgroundImage.getWidth(null) == -1) {
                backgroundImage = new ImageIcon("backgroundWaittingRoom.png").getImage();
            }
        } catch (Exception e) {
            System.out.println("Background error");
        }

        // 1. العنوان - سكري ونزلته تحت شوي (زيادة الهامش لـ 60)
        JLabel title = new JLabel("Waiting Room", JLabel.CENTER);
        title.setFont(new Font("Serif", Font.BOLD, 48));
        title.setForeground(offWhite); 
        title.setBorder(BorderFactory.createEmptyBorder(60, 0, 0, 0)); 
        add(title, BorderLayout.NORTH);

        // 2. منطقة الرسم المخصص
        JPanel gameTablePanel = new JPanel() {
            @Override
            protected void paintComponent(Graphics g) {
                Graphics2D g2d = (Graphics2D) g;
                drawWaitingArea(g2d, getWidth(), getHeight());
            }
        };
        gameTablePanel.setOpaque(false); 
        add(gameTablePanel, BorderLayout.CENTER);

        // 3. الرسالة السفلية - انجليزي وسكري غامق ورفعتها فوق (زيادة الهامش لـ 60)
        JLabel statusLabel = new JLabel("The game will start once the room is full...", JLabel.CENTER);
        statusLabel.setFont(new Font("Serif", Font.ITALIC, 20));
        statusLabel.setForeground(darkOffWhite);
        statusLabel.setBorder(BorderFactory.createEmptyBorder(0, 0, 60, 0));
        add(statusLabel, BorderLayout.SOUTH);
    }

    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);
        if (backgroundImage != null) {
            g.drawImage(backgroundImage, 0, 0, getWidth(), getHeight(), this);
        } else {
            g.setColor(new Color(30, 30, 30));
            g.fillRect(0, 0, getWidth(), getHeight());
        }
    }

    public void updateWaitingPlayers(List<String> players) {
        this.currentPlayers = players;
        repaint();
    }

    private void drawWaitingArea(Graphics2D g2d, int width, int height) {
        g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

        int rectW = 500;
        int rectH = 300;
        int rectX = (width - rectW) / 2;
        int rectY = (height - rectH) / 2;

        // رسم جسم الطاولة
        g2d.setColor(new Color(70, 45, 25));
        g2d.fill(new RoundRectangle2D.Double(rectX, rectY, rectW, rectH, 20, 20));

        // --- إضافة الخطوط الفاصلة هنا (جعلناها بلون فاتح لتظهر) ---
        g2d.setColor(new Color(245, 241, 222, 50)); // لون سكري بـ Alpha منخفض (شفاف)
        g2d.setStroke(new BasicStroke(1.5f));
        // خط أفقي
        g2d.drawLine(rectX, rectY + rectH / 2, rectX + rectW, rectY + rectH / 2);
        // خط عمودي
        g2d.drawLine(rectX + rectW / 2, rectY, rectX + rectW / 2, rectY + rectH);

        // إطار الطاولة الخارجي
        g2d.setColor(new Color(40, 25, 15));
        g2d.setStroke(new BasicStroke(3));
        g2d.draw(new RoundRectangle2D.Double(rectX, rectY, rectW, rectH, 20, 20));

        // مواقع اللاعبين
        int[][] positions = {
                {rectX + 125, rectY + 75},
                {rectX + 375, rectY + 75},
                {rectX + 125, rectY + 225},
                {rectX + 375, rectY + 225}
        };

        for (int i = 0; i < 4; i++) {
            boolean isPresent = (i < currentPlayers.size());
            String playerName = isPresent ? currentPlayers.get(i) : "Waiting...";
            drawPlayer(g2d, positions[i][0], positions[i][1], isPresent, playerName);
        }
    }

    private void drawPlayer(Graphics2D g2d, int x, int y, boolean isPresent, String name) {
        int headSize = 40;
        int bodyW = 50;
        int bodyH = 60;

        if (isPresent) {
            // لون أزرق نيلي دافئ (أوضح وأجمل مع البني)
            g2d.setColor(new Color(60, 110, 125)); 
        } else {
            // لون رمادي غامق شفاف للأماكن الفارغة
            g2d.setColor(new Color(40, 40, 40, 120)); 
        }

        // رسم الشخص
        g2d.fill(new Ellipse2D.Double(x - headSize / 2, y - bodyH - headSize / 2 - 5, headSize, headSize));
        g2d.fill(new RoundRectangle2D.Double(x - bodyW / 2, y - bodyH / 2, bodyW, bodyH, 15, 15));

        // حدود الشخص
        g2d.setColor(new Color(20, 20, 20));
        g2d.setStroke(new BasicStroke(2));
        g2d.draw(new Ellipse2D.Double(x - headSize / 2, y - bodyH - headSize / 2 - 5, headSize, headSize));
        g2d.draw(new RoundRectangle2D.Double(x - bodyW / 2, y - bodyH / 2, bodyW, bodyH, 15, 15));

        // الأسماء باللون السكري
        g2d.setFont(new Font("Serif", isPresent ? Font.BOLD : Font.ITALIC, 17));
        g2d.setColor(new Color(245, 241, 222));
        FontMetrics fm = g2d.getFontMetrics();
        int nameX = x - fm.stringWidth(name) / 2;
        g2d.drawString(name, nameX, y + bodyH / 2 + 30);
    }
}
